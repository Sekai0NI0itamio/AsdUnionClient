{
  "manifest_version": 3,
  "name": "Router Tunnel Toggle",
  "version": "1.1.0",
  "description": "Route selected domains through RouterTunnel's local HTTP proxy.",
  "permissions": ["proxy", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Router Tunnel"
  },
  "background": {
    "service_worker": "background.js"
  }
}
